description="Opens external Shaarli links in a new tab, with same-window exceptions, forced-new-tab overrides, focus behaviour and opt-out support."
version="0.3.0"
parameters="URL_EXTERN_ENABLED;URL_EXTERN_EXCEPTIONS;URL_EXTERN_FORCE_NEW_TAB;URL_EXTERN_NEW_TAB_FOCUS;URL_EXTERN_RESPECT_EXPLICIT_TARGETS"
parameter.URL_EXTERN_ENABLED="Enable behaviour while the plugin itself is active. Use 1/true/on/yes to enable, 0/false/off/no to disable. Default: 1"
parameter.URL_EXTERN_EXCEPTIONS="Comma-separated same-window exceptions. Supports domains, hosts with ports, URL patterns and wildcards. Examples: example.org, *.example.com, https://docs.example.net/manual/*"
parameter.URL_EXTERN_FORCE_NEW_TAB="Comma-separated URLs/domains that must open in a new tab even if they also match the exception list. Supports the same pattern syntax."
parameter.URL_EXTERN_NEW_TAB_FOCUS="New-tab focus behaviour: new or current. Use new to let the browser move focus to the opened tab, or current to try to keep focus on Shaarli. Default: new"
parameter.URL_EXTERN_RESPECT_EXPLICIT_TARGETS="Do not override links that already have a target attribute. Use 1/true/on/yes to respect existing targets, 0/false/off/no to force plugin behaviour. Default: 0"
